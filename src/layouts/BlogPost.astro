---
import type { CollectionEntry } from 'astro:content'
import FormattedDate from '@/components/FormattedDate.astro'
import Tag from '@/components/Tag.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { dateLabel } from '@/utils/date'

type Props = CollectionEntry<'blog'>['data'] & { id: string }

const { title, description, pubDate, updatedDate, tags, id } = Astro.props

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  keywords: tags.join(', '),
}
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article>
    <header
      class="mb-8 border-b border-zinc-200 pb-6 dark:border-zinc-800"
      transition:name={`post-${id}`}
    >
      <h1 class="mb-3 text-3xl leading-tight font-bold text-zinc-900 dark:text-zinc-100">
        {title}
      </h1>
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <span class="text-sm text-zinc-500 dark:text-zinc-400">
          {dateLabel(updatedDate)}
          <FormattedDate date={updatedDate ?? pubDate} />
        </span>
        {tags.map((tag) => <Tag name={tag} />)}
      </div>
      <p class="mb-3 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
        {description}
      </p>
    </header>
    <div
      class="prose prose-zinc dark:prose-invert prose-headings:font-bold prose-headings:text-zinc-900 dark:prose-headings:text-zinc-100 prose-a:text-emerald-600 dark:prose-a:text-emerald-400 prose-a:underline prose-pre:rounded-none prose-pre:border prose-pre:border-zinc-200 dark:prose-pre:border-zinc-800 prose-blockquote:border-l-emerald-500 prose-blockquote:text-zinc-600 dark:prose-blockquote:text-zinc-400 prose-hr:border-zinc-200 dark:prose-hr:border-zinc-800 max-w-none"
    >
      <slot />
    </div>
  </article>
</BaseLayout>
