---
import { tagToSlug } from '@/utils/tags'

interface Props {
  name: string
}

const { name } = Astro.props
const href = `/blog/tags/${tagToSlug(name)}/`
---

<a
  href={href}
  class="relative z-10 inline-block bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-700 transition-colors hover:bg-emerald-200 dark:bg-emerald-950 dark:text-emerald-300 dark:hover:bg-emerald-900"
>
  {name}
</a>
