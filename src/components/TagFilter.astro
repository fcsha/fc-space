---
import { filterButtonClass, tagToSlug } from '@/utils/tags'

interface Props {
  tags: { name: string; count: number }[]
  activeTag?: string | null
}

const { tags, activeTag = null } = Astro.props
---

<div class="mb-6 flex flex-wrap items-center gap-2">
  <a
    href="/blog/"
    class:list={[
      filterButtonClass.base,
      activeTag === null ? filterButtonClass.active : filterButtonClass.inactive,
    ]}
  >
    全部
  </a>
  {
    tags.map(({ name, count }) => (
      <a
        href={`/blog/tags/${tagToSlug(name)}/`}
        class:list={[
          filterButtonClass.base,
          activeTag === name ? filterButtonClass.active : filterButtonClass.inactive,
        ]}
      >
        {name}<span class="ml-1 opacity-60">{count}</span>
      </a>
    ))
  }
</div>
