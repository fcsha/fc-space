---
import type { CollectionEntry } from 'astro:content'
import FormattedDate from '@/components/FormattedDate.astro'
import Tag from '@/components/Tag.astro'
import { dateLabel, dateTitle } from '@/utils/date'

interface Props {
  posts: CollectionEntry<'blog'>[]
}

const { posts } = Astro.props
---

{
  posts.length === 0 ? (
    <p class="py-12 text-center text-zinc-500 dark:text-zinc-400">该标签下暂无文章。</p>
  ) : (
    <ul class="flex flex-col gap-4">
      {posts.map((post) => (
        <li>
          <article class="relative border border-zinc-200 bg-white p-5 transition-colors hover:border-emerald-400 hover:shadow-sm dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-emerald-600">
            <h2 class="mb-1 text-lg font-bold text-zinc-900 dark:text-zinc-100">
              <a href={`/blog/${post.id}/`} class="after:absolute after:inset-0">
                {post.data.title}
              </a>
            </h2>
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <span
                class="text-sm text-zinc-500 dark:text-zinc-400"
                title={dateTitle(post.data.pubDate, post.data.updatedDate)}
              >
                {dateLabel(post.data.updatedDate)}{' '}
                <FormattedDate date={post.data.updatedDate ?? post.data.pubDate} />
              </span>
              {post.data.tags.map((tag) => (
                <Tag name={tag} />
              ))}
            </div>
            <p class="text-sm text-zinc-500 dark:text-zinc-400">{post.data.description}</p>
          </article>
        </li>
      ))}
    </ul>
  )
}
