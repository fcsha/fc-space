{
  "$schema": "https://www.schemastore.org/prettierrc.json",
  "printWidth": 100,
  "singleQuote": true,
  "semi": false,
  "plugins": ["prettier-plugin-astro", "prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": "*.astro",
      "options": {
        "parser": "astro"
      }
    }
  ]
}
